# ===== Produção (Droplet) — copie para .env e ajuste =====
# Deploy por IP (origem única via Caddy na porta 80): a Web chama a API em /api.
# Quando houver domínio, troque por https://seu-dominio e https://seu-dominio/api.
WEB_ORIGIN="http://SEU_IP"
API_PUBLIC_URL="/api"

# Postgres (no próprio Droplet)
POSTGRES_USER="unicorp"
POSTGRES_PASSWORD="troque-esta-senha-forte"
POSTGRES_DB="unicorp"
DATABASE_URL="postgresql://unicorp:troque-esta-senha-forte@postgres:5432/unicorp?schema=public"

# JWT (gere com: openssl rand -hex 32)
JWT_ACCESS_SECRET=""
JWT_REFRESH_SECRET=""

# IA (Fase 6)
GEMINI_API_KEY=""

# SMTP (convites/recuperação de senha)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Universidade Corporativa <no-reply@example.com>"
