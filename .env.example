# ============ Banco de dados ============
DATABASE_URL="postgresql://unicorp:unicorp@localhost:5432/unicorp?schema=public"
DIRECT_URL="postgresql://unicorp:unicorp@localhost:5432/unicorp?schema=public"

# ============ Redis ============
REDIS_URL="redis://localhost:6379"

# ============ API ============
PORT=3333
API_PREFIX=api
API_CORS_ORIGIN="http://localhost:3000"
NODE_ENV=development

# JWT
JWT_ACCESS_SECRET="troque-este-segredo-de-acesso"
JWT_REFRESH_SECRET="troque-este-segredo-de-refresh"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# Uploads (disk storage local; futuro: DigitalOcean Spaces)
UPLOAD_DIR="./uploads"
MAX_UPLOAD_MB=512
# % mínimo de vídeo assistido para marcar a aula como concluída
VIDEO_COMPLETION_THRESHOLD=90

# SMTP (convites / recuperação de senha) — opcional em dev
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Universidade Corporativa <no-reply@localhost>"

# IA (Fase 6) — Gemini
GEMINI_API_KEY=""

# ============ Web ============
NEXT_PUBLIC_API_URL="http://localhost:3333/api"
